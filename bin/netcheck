#!/usr/bin/env bash

set -euo pipefail

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

CURL_OPTS=(-s -m 10 -L --compressed)

# ========== 第一部分：出口 IP 信息 ==========

print_header() {
    echo -e "\n${BOLD}${CYAN}═══ $1 ═══${RESET}\n"
}

fetch_ipinfo() {
    local url='https://ipinfo.io/json'
    local resp
    resp=$(curl "${CURL_OPTS[@]}" "$url" 2>/dev/null) || {
        echo -e "  ${RED}请求失败${RESET}"
        return
    }
    local ip country region city org
    ip=$(echo "$resp" | jq -r '.ip // empty')
    country=$(echo "$resp" | jq -r '.country // ""')
    region=$(echo "$resp" | jq -r '.region // ""')
    city=$(echo "$resp" | jq -r '.city // ""')
    org=$(echo "$resp" | jq -r '.org // ""' | sed -E 's/^AS[0-9]+[[:space:]]*//')
    if [[ -n "$ip" ]]; then
        local flag prefix=""
        flag=$(country_flag "$country")
        [[ -n "$flag" ]] && prefix="${flag} "
        echo -e "  IP:   ${GREEN}${ip}${RESET}"
        echo -e "  位置: ${YELLOW}${prefix}${country} ${region} ${city}${RESET}"
        [[ -n "$org" ]] && echo -e "  组织: ${YELLOW}${org}${RESET}"
    else
        echo -e "  ${RED}解析失败${RESET}: $resp"
    fi
}

fetch_ipsb() {
    local url='https://api.ip.sb/geoip'
    local resp
    resp=$(curl "${CURL_OPTS[@]}" "$url" 2>/dev/null) || {
        echo -e "  ${RED}请求失败${RESET}"
        return
    }
    local ip country country_code region city isp org
    ip=$(echo "$resp" | jq -r '.ip // empty')
    country=$(echo "$resp" | jq -r '.country // ""')
    country_code=$(echo "$resp" | jq -r '.country_code // ""')
    region=$(echo "$resp" | jq -r '.region // ""')
    city=$(echo "$resp" | jq -r '.city // ""')
    isp=$(echo "$resp" | jq -r '.isp // ""')
    org=$(echo "$resp" | jq -r '.organization // ""')
    if [[ -n "$ip" ]]; then
        local flag prefix=""
        flag=$(country_flag "$country_code")
        [[ -n "$flag" ]] && prefix="${flag} "
        echo -e "  IP:   ${GREEN}${ip}${RESET}"
        echo -e "  位置: ${YELLOW}${prefix}${country} ${region} ${city}${RESET}"
        echo -e "  ISP:  ${YELLOW}${isp}${RESET}"
        [[ -n "$org" && "$org" != "$isp" ]] && echo -e "  组织: ${YELLOW}${org}${RESET}"
    else
        echo -e "  ${RED}解析失败${RESET}: $resp"
    fi
}

country_flag() {
    local code=${1^^}
    [[ ${#code} -ne 2 ]] && return
    local c1 c2 hex1 hex2
    printf -v c1 '%d' "'${code:0:1}"
    printf -v c2 '%d' "'${code:1:1}"
    ((c1 < 65 || c1 > 90 || c2 < 65 || c2 > 90)) && return
    printf -v hex1 '%08x' $((0x1F1E6 + c1 - 65))
    printf -v hex2 '%08x' $((0x1F1E6 + c2 - 65))
    printf "\U${hex1}\U${hex2}"
}

