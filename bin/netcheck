fetch_ipchecking() {
    local url="https://ptest-$1.ipcheck.ing/cdn-cgi/trace"
    local resp
    resp=$(curl "${CURL_OPTS[@]}" "$url" 2>/dev/null) || {
        echo -e "  ${RED}请求失败${RESET}"
        return
    }
    local ip loc colo
    ip=$(echo "$resp" | sed -n 's/^ip=//p')
    loc=$(echo "$resp" | sed -n 's/^loc=//p')
    colo=$(echo "$resp" | sed -n 's/^colo=//p')
    if [[ -n "$ip" ]]; then
        local flag cname prefix="" suffix=""
        flag=$(country_flag "$loc")
        cname=$(country_name "$loc")
        [[ -n "$flag" ]] && prefix="${flag} "
        [[ -n "$cname" ]] && suffix=" (${cname})"
        echo -e "  IP:   ${GREEN}${ip}${RESET}"
        echo -e "  地区: ${YELLOW}${prefix}${loc}${suffix}${RESET}"
        local city
        city=$(colo_city "$colo")
        if [[ -n "$city" ]]; then
            echo -e "  节点: ${YELLOW}${colo} (${city})${RESET}"
        else
            echo -e "  节点: ${YELLOW}${colo}${RESET}"
        fi
    else
        echo -e "  ${RED}解析失败${RESET}"
    fi
}

# ========== 第二部分：网站延迟检测 ==========

pad_name() {
    local name=$1 width=$2
    local char_len=${#name}
    local byte_len
    byte_len=$(printf '%s' "$name" | wc -c | tr -d ' ')
    # 每个 3 字节 UTF-8 宽字符显示占 2 列，多出 1 列
    local extra=$(((byte_len - char_len) / 2))
    local display_width=$((char_len + extra))
    local pad=$((width - display_width))
    printf '%s' "$name"
    ((pad > 0)) && printf '%*s' "$pad" ''
}

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

measure_latency() {
    local name=$1 url=$2
    local probe_result
    probe_result=$("$SCRIPT_DIR/netcheck-probe" "$url")

    local ok fail avg min_ms max_ms codes
    read -r ok fail avg min_ms max_ms codes <<<"$probe_result"

    local padded
    padded=$(pad_name "$name" 14)

    if ((ok == 0)); then
        printf "  %s ${RED}%s${RESET}\n" "$padded" "超时/不可达"
        return
    fi

    local color=$GREEN
    if ((avg > 1000)); then
        color=$RED
    elif ((avg > 300)); then
        color=$YELLOW
    fi

    local warn=""
    if ((fail > 0)); then
        warn="  ${RED}[${fail}/3 失败]${RESET}"
    fi

    printf "  %s ${color}%4d ms${RESET}  ${DIM}(%4d~%-4d ms, HTTP %s)${RESET}%b\n" "$padded" "$avg" "$min_ms" "$max_ms" "$codes" "$warn"
}

# ========== 主流程 ==========

print_header "出口 IP 信息"

# 用临时文件保持输出顺序
tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

(
    echo -e "${BOLD}DIRECT: [ipinfo.io]${RESET}"
    fetch_ipinfo
) >"$tmpdir/ip_01" &

(
    echo -e "${BOLD}PROXY: [ip.sb]${RESET}"
    fetch_ipsb
) >"$tmpdir/ip_02" &

i=0
for name in "AI" "Claude" "ChatGPT" "YouTube" "EMBY"; do
    ((i++)) || true
    (
        echo -e "${BOLD}$name: [ptest-$i.ipcheck.ing]${RESET}"
        fetch_ipchecking "$i"
    ) >"$tmpdir/ip_1$i" &
done

wait
cat "$tmpdir"/ip_*

print_header "网站延迟检测"

# 定义目标网站
declare -a sites=(
    "百度|https://www.baidu.com/favicon.ico"
    "微信|https://res.wx.qq.com/a/wx_fed/assets/res/NTI4MWU5.ico"
    "淘宝|https://www.taobao.com/favicon.ico"
    "京东|https://www.jd.com/favicon.ico"
    "Cloudflare|https://www.cloudflare.com/favicon.ico"
    "Google|https://www.google.com/favicon.ico"
    "YouTube|https://www.youtube.com/favicon.ico"
    "GitHub|https://github.com/favicon.ico"
    "ChatGPT|https://chatgpt.com/favicon.ico"
    "OpenAI|https://api.openai.com/"
    "Anthropic|https://api.anthropic.com/"
    "Claude|https://claude.ai/favicon.ico"
    "Gemini|https://gemini.google/favicon.ico"
    "YouTube|https://www.youtube.com/favicon.ico"
    "ASK机场服|https://ask.ash.yt/favicon.ico"
    "JMS机场服|https://tv.ash.yt/favicon.ico"
)

for i in "${!sites[@]}"; do
    IFS='|' read -r name url <<<"${sites[$i]}"
    (
        measure_latency "$name" "$url" >"$tmpdir/$i"
    ) &
done
wait

for i in "${!sites[@]}"; do
    cat "$tmpdir/$i"
done

echo
