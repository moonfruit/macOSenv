#!/usr/bin/env bash
/usr/bin/ssh "$@" || exit

read -r U H < <(/usr/bin/ssh -G "$@" 2>/dev/null | awk '
    $1=="user"     {u=$2}
    $1=="hostname" {h=$2}
    END            {print u, h}
')

[[ -z $U || -z $H ]] && exit

VAR="$U@$H"
SAVED=$HOME/.ssh/saved_hosts

if ! rg -Fxq "$VAR" "$SAVED"; then
    echo "$VAR" >>"$SAVED"
    uhsort -ui "$SAVED"
fi
