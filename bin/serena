#!/usr/bin/env bash
set -euo pipefail

SERENA="$WORKSPACE/python/serena"

PULL_STAMP="$SERENA/.git/FETCH_HEAD"
if [[ ! -f "$PULL_STAMP" ]] || (($(date +%s) - $(date -r "$PULL_STAMP" +%s) > 86400)); then
  echo "Pulling latest changes for Serena..." >&2
  git -C "$SERENA" checkout uv.lock >&2
  git -C "$SERENA" pull >&2
fi

exec uv --directory "$SERENA" run serena "$@"
