#!/usr/bin/env bash
set -euo pipefail

caskroom="$(brew --prefix)/Caskroom/sqlcl"
version=$(fd -C "$caskroom" --exact-depth 1 -td | sort -V | tail -n 1)

if [[ -z "${version:-}" ]]; then
    echo "sqlcl: no version found under $caskroom" >&2
    exit 1
fi

export ORACLE_HOME="/opt/homebrew/opt/oracle-instantclient/libexec"
export JAVA_TOOL_OPTIONS="-Djava.library.path=$ORACLE_HOME"

# Java 26+
JAVA_TOOL_OPTIONS="$JAVA_TOOL_OPTIONS --enable-final-field-mutation=ALL-UNNAMED"

if (($#)); then
    exec "$caskroom/$version/sqlcl/bin/sql" "$@"
else
    exec "$caskroom/$version/sqlcl/bin/sql" /nolog
fi

# cspell:words sqlcl
