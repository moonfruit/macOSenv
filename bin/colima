#!/bin/bash
set -euo pipefail
source "$ENV/lib/bash/console.sh"
source "$ENV/lib/bash/native.sh"

COLIMA="$(brew --prefix)/bin/colima"

should-use-dark() {
    [[ $1 == start || $1 == stop || $1 == restart || $1 == ssh ]]
}

if should-use-dark "${1:-}" && has-command dark && is-solarized; then
    dark "$COLIMA" "$@"
else
    exec "$COLIMA" "$@"
fi
