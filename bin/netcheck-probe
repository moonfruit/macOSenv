#!/usr/bin/env bash
# 对单个 URL 发起 3 次并发探测，输出: ok fail avg_ms min_ms max_ms codes
# 用法: netcheck-probe <url>

set -euo pipefail

url=$1
CURL_OPTS=(-s -m 10 -L --compressed)

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

for i in 1 2 3; do
    (
        result=$(curl "${CURL_OPTS[@]}" -o /dev/null -w '%{http_code} %{time_total}' "$url" 2>/dev/null) && {
            echo "$result" > "$tmpdir/$i"
        } || {
            echo "FAIL" > "$tmpdir/$i"
        }
    ) &
done
wait

ok=0 fail=0 total_ms=0 min_ms=999999 max_ms=0 codes=""
for i in 1 2 3; do
    result=$(cat "$tmpdir/$i")
    if [[ "$result" == "FAIL" ]]; then
        fail=$(( fail + 1 ))
    else
        http_code=${result%% *}
        time_total=${result#* }
        ms=$(awk "BEGIN { printf \"%.0f\", $time_total * 1000 }")
        total_ms=$(( total_ms + ms ))
        (( ms < min_ms )) && min_ms=$ms
        (( ms > max_ms )) && max_ms=$ms
        ok=$(( ok + 1 ))
        codes="${codes:+$codes/}$http_code"
    fi
done

if (( ok > 0 )); then
    avg=$(( total_ms / ok ))
else
    avg=0 min_ms=0 max_ms=0
fi

echo "$ok $fail $avg $min_ms $max_ms $codes"
