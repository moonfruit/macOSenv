{
  "env": {
    "API_TIMEOUT_MS": "600000",
    "MCP_TIMEOUT": "120000",
    "MCP_TOOL_TIMEOUT": "120000"
  },
  "permissions": {
    "allow": [
      "Bash(brew --version)",
      "Bash(brew info:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(go build:*)",
      "Bash(go doc:*)",
      "Bash(go fmt:*)",
      "Bash(go list:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(ruff check:*)",
      "Bash(shellcheck:*)",
      "Bash(shfmt:*)",
      "Bash(svn diff:*)",
      "Bash(svn info:*)",
      "Bash(svn log:*)",
      "Bash(xargs cat:*)",
      "Bash(xargs ls:*)",
      "Bash(xxd:*)",
      "Bash(yes)",
      "mcp__chrome-devtools__get_network_request",
      "mcp__chrome-devtools__list_network_requests",
      "mcp__chrome-devtools__list_pages",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__context7__resolve-library-id",
      "mcp__dash__list_installed_docsets",
      "mcp__dash__load_documentation_page",
      "mcp__dash__search_documentation",
      "mcp__minimax__web_search",
      "Read(//private/tmp/**)",
      "Read(//tmp/**)",
      "WebFetch(domain:docs.anthropic.com)"
    ],
    "deny": []
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/moon/Workspace.localized/env/bin/claude-hooks/notification.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    }
  },
  "verbose": false,
  "model": "opus"
}
