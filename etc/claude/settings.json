{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "MCP_TIMEOUT": "120000",
    "MCP_TOOL_TIMEOUT": "300000"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(brew --version)",
      "Bash(brew info:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(gh search:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git ls-tree:*)",
      "Bash(git show:*)",
      "Bash(go build:*)",
      "Bash(go doc:*)",
      "Bash(go env:*)",
      "Bash(go fmt:*)",
      "Bash(go list:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(ruff check:*)",
      "Bash(shellcheck:*)",
      "Bash(shfmt:*)",
      "Bash(svn diff:*)",
      "Bash(svn info:*)",
      "Bash(svn log:*)",
      "Bash(xargs cat:*)",
      "Bash(xargs ls:*)",
      "Bash(xxd:*)",
      "Bash(yes)",
      "Read(//private/tmp/**)",
      "Read(//tmp/**)",
      "WebFetch(domain:docs.anthropic.com)",
      "mcp__chrome-devtools__get_network_request",
      "mcp__chrome-devtools__list_network_requests",
      "mcp__chrome-devtools__list_pages",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__context7__resolve-library-id",
      "mcp__dash__list_installed_docsets",
      "mcp__dash__load_documentation_page",
      "mcp__dash__search_documentation",
      "mcp__homebrew__style",
      "mcp__minimax__web_search",
      "mcp__plugin_github_github__search_issues",
      "mcp__plugin_github_github__search_pull_requests"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/moon/Workspace.localized/env/bin/claude-hooks/notification.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/moon/Workspace.localized/env/bin/claude-hooks/ccstatusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "codex@openai-codex": true,
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "verbose": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
