# Group subcommand dispatch — shared by `workspace group` and `workspace-group`.
# Expects $words to have been shifted so $words[1] is the group subcommand.
_cmux_workspace_group_subs() {
  local -a subs=(
    'list:List groups' 'create:Create a group'
    'ungroup:Dissolve a group, keep members' 'delete:Delete a group AND its workspaces'
    'rename:Rename a group' 'collapse:Collapse a group' 'expand:Expand a group'
    'pin:Pin a group' 'unpin:Unpin a group'
    'add:Add a workspace to a group' 'remove:Remove a workspace from its group'
    'set-anchor:Set the group anchor workspace'
    'new-workspace:Create a workspace in a group'
    'set-color:Set group color' 'set-icon:Set group icon'
    'move:Move a group' 'focus:Focus the group anchor'
  )
  _describe -t group-subcommands 'group subcommand' subs
}

_cmux_workspace_group_args() {
  # All group subcommands honor --json.
  case ${words[1]} in
    list)
      _arguments '--json[Output JSON]' ;;
    create)
      _arguments \
        '--name[Group name]:name:' \
        '--cwd[Working directory]:dir:_path_files -/' \
        '--from[Source workspace ids (comma-separated)]:ids:' \
        '--json[Output JSON]' ;;
    ungroup|delete|collapse|expand|pin|unpin|focus)
      _arguments '1:group:_cmux_ref' '--json[Output JSON]' ;;
    rename)
      _arguments '1:group:_cmux_ref' '--name[New name]:name:' '--json[Output JSON]' ;;
    add)
      _arguments '--group[Group]:group:_cmux_ref' '--workspace[Workspace]:workspace:_cmux_ref' '--json[Output JSON]' ;;
    remove)
      _arguments '--workspace[Workspace]:workspace:_cmux_ref' '--json[Output JSON]' ;;
    set-anchor)
      _arguments '--group[Group]:group:_cmux_ref' '--workspace[Workspace]:workspace:_cmux_ref' '--json[Output JSON]' ;;
    new-workspace)
      _arguments '1:group:_cmux_ref' '--placement[Placement]:placement:(afterCurrent top end)' '--json[Output JSON]' ;;
    set-color)
      _arguments '1:group:_cmux_ref' '--hex[Color #RRGGBB]:hex:' '--json[Output JSON]' ;;
    set-icon)
      _arguments '1:group:_cmux_ref' '--symbol[SF Symbol]:symbol:' '--json[Output JSON]' ;;
    move)
      _arguments '1:group:_cmux_ref' \
        '--to-index[Target index]:n:' \
        '--before[Before group]:group:_cmux_ref' \
        '--after[After group]:group:_cmux_ref' \
        '--json[Output JSON]' ;;
  esac
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
_cmux() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  # Inputs accept UUIDs, short refs (window:1/workspace:2/pane:3/surface:4) or indexes.
  local -a _cmux_target_opts=(
    '--workspace[Target workspace]:workspace:_cmux_ref'
    '--surface[Target surface]:surface:_cmux_ref'
    '--pane[Target pane]:pane:_cmux_ref'
    '--window[Target window]:window:_cmux_ref'
  )
  local -a _cmux_focus_opts=(
    '--focus[Focus after action]:focus:(true false)'
    '--no-focus[Do not focus after action]'
  )

  _arguments -C \
    '(- *)'{-h,--help}'[Show help]' \
    '--password[Socket auth password]:password:' \
    '--id-format[ID output format]:format:(refs uuids both)' \
    '1: :->command' \
    '*:: :->args' \
    && return 0

  case $state in
    command)
      # First positional may be a directory (open in new workspace) or a command.
      _alternative \
        'commands:command:_cmux_commands' \
        'directories:directory:_path_files -/'
      ;;
    args)
      local cmd=${line[1]}
      case $cmd in
        docs)
          _values 'topic' settings shortcuts api browser agents dock sidebars ;;
        settings)
          _values 'settings action' open path docs ;;
        config)
          _values 'config action' doctor check validate path paths docs documentation reload ;;
        themes)
          _values 'themes action' list set clear ;;
        feed)
          _values 'feed action' tui clear ;;
        agent-hibernation)
          _values 'state' on off ;;
        auth)
          _values 'auth action' status login logout ;;
        set-app-focus)
          _values 'app focus' active inactive clear ;;
        vm|cloud)
          _values 'vm action' new ls rm exec shell ssh ;;
        surface)
          if (( CURRENT == 2 )); then
            _values 'surface action' resume
          else
            _values 'resume action' set show get clear
          fi ;;
        right-sidebar)
          _values 'right-sidebar action' \
            toggle show hide focus set mode files find vault sessions feed dock ;;
        sidebar)
          _values 'sidebar action' validate reload select open ;;
        hooks)
          if (( CURRENT == 2 )); then
            _values 'hooks action' setup uninstall feed
          else
            _arguments \
              '--agent[Agent name]:agent:' \
              '--project[Limit to project (opencode)]' \
              '--source[Hook source agent]:agent:' \
              '--event[Hook event]:event:'
          fi ;;
        workspace)
          if (( CURRENT == 2 )); then
            _values 'workspace subcommand' \
              'list[List workspaces in a window]' \
              'create[Create a workspace]' \
              'env[Print a workspace'\''s configured env vars]' \
              'close[Close a workspace]' \
              'rename[Rename a workspace]' \
              'select[Make a workspace active]' \
              'reconnect[Reconnect a remote (SSH) workspace]' \
              'disconnect[Stop a remote workspace connection]' \
              'group[Workspace group operations]'
            return
          fi
          # Drop 'workspace' so $words[1] becomes the subcommand.
          (( CURRENT-- )); shift words
          case ${words[1]} in
            list)
              _arguments '--json[Output JSON]' '--window[Window]:window:_cmux_ref' ;;
            create)
              _arguments \
                '--name[Title]:title:' '--description[Description]:text:' \
                '--cwd[Working directory]:dir:_path_files -/' \
                '--command[Command]:command:' '--layout[Layout JSON]:json:' \
                '--window[Window]:window:_cmux_ref' "$_cmux_focus_opts[@]" ;;
            env)
              _arguments '1:workspace:_cmux_ref' \
                '--mask[Redact the values]' '--window[Window]:window:_cmux_ref' ;;
            close|select)
              _arguments '1:workspace:_cmux_ref' '--window[Window]:window:_cmux_ref' ;;
            rename)
              _arguments '1:workspace:_cmux_ref' \
                '--title[New title]:title:' '--window[Window]:window:_cmux_ref' ;;
            reconnect|disconnect)
              _arguments '1:workspace:_cmux_ref' \
                '--workspace[Workspace]:workspace:_cmux_ref' \
                '--window[Window]:window:_cmux_ref' ;;
            group)
              if (( CURRENT == 2 )); then
                _cmux_workspace_group_subs
                return
              fi
              (( CURRENT-- )); shift words
              _cmux_workspace_group_args ;;
          esac ;;
        workspace-group)
          if (( CURRENT == 2 )); then
            _cmux_workspace_group_subs
            return
          fi
          (( CURRENT-- )); shift words
          _cmux_workspace_group_args ;;
        new-split|split-off|drag-surface-to-split)
          _arguments \
            '1:direction:(left right up down)' \
            "$_cmux_target_opts[@]" "$_cmux_focus_opts[@]" ;;
        resize-pane)
          _arguments \
            '-L[Resize left]' '-R[Resize right]' \
            '-U[Resize up]' '-D[Resize down]' \
            '--amount[Cells]:n:' "$_cmux_target_opts[@]" ;;
        open)
          _arguments '*:path or url:_files' \
            "$_cmux_target_opts[@]" "$_cmux_focus_opts[@]" ;;
        diff)
          _arguments \
            '1:patch file:_files' \
            '--source[Diff source]:source:(unstaged staged branch last-turn)' \
            '--unstaged' '--staged' '--branch' '--last-turn' \
            '--cwd[Working directory]:dir:_path_files -/' \
            '--base[Base ref]:ref:' \
            '--title[Title]:title:' \
            '--layout[Layout]:layout:(split unified)' \
            '--font-size[Font size]:points:' \
            "$_cmux_target_opts[@]" "$_cmux_focus_opts[@]" ;;
        markdown)
          _arguments '1:action or path:(open)' '*:path:_files' \
            '--focus[Focus]:focus:(true false)' ;;
        new-pane)
          _arguments \
            '--type[Pane type]:type:(terminal browser)' \
            '--direction[Direction]:direction:(left right up down)' \
            '--url[URL]:url:' "$_cmux_target_opts[@]" "$_cmux_focus_opts[@]" ;;
        new-surface)
          _arguments \
            '--type[Surface type]:type:(terminal browser agent-session)' \
            '--url[URL]:url:' \
            '--provider[Provider]:provider:(codex claude opencode)' \
            '--renderer[Renderer]:renderer:(react solid)' \
            "$_cmux_target_opts[@]" "$_cmux_focus_opts[@]" ;;
        new-workspace)
          _arguments \
            '--name[Title]:title:' '--description[Description]:text:' \
            '--cwd[Working directory]:dir:_path_files -/' \
            '--command[Command]:command:' '--layout[Layout JSON]:json:' \
            '--group[Target group]:group:_cmux_ref' \
            '--group-placement[Placement in group]:placement:(afterCurrent top end)' \
            '--group-reference[Reference workspace in group]:workspace:_cmux_ref' \
            '--window[Window]:window:_cmux_ref' "$_cmux_focus_opts[@]" ;;
        ssh)
          _arguments \
            '1:destination:_ssh_hosts' \
            '--name[Title]:title:' '--port[Port]:port:' \
            '--identity[Identity file]:path:_files' \
            '(-A --forward-agent)'{-A,--forward-agent}'[Forward agent]' \
            '(-a --no-forward-agent)'{-a,--no-forward-agent}'[Do not forward agent]' \
            '--ssh-option[SSH option]:opt:' \
            '--window[Window]:window:_cmux_ref' '--no-focus[Do not focus]' \
            '*::remote command:_command_names' ;;
        ssh-tmux)
          _arguments \
            '1:destination:_ssh_hosts' \
            '--port[Port]:port:' \
            '--identity[Identity file]:path:_files' \
            '--no-focus[Do not focus]' ;;
        remotes|remote)
          if (( CURRENT == 2 )); then
            _values 'remotes action' list add remove
          else
            (( CURRENT-- )); shift words
            case ${words[1]} in
              list)
                _arguments '--json[Output JSON]' ;;
              add)
                _arguments \
                  '1:name:' \
                  '*--route[Attach route host:port]:route:' \
                  '--tag[Tag]:tag:' '--json[Output JSON]' ;;
              remove)
                _arguments '1:name or deviceId:' '--json[Output JSON]' ;;
            esac
          fi ;;
        top)
          _arguments \
            '--all' '--processes' '--flat' \
            '--sort[Sort by]:sort:(cpu mem proc)' \
            '--format[Output format]:format:(tree tsv)' \
            "$_cmux_target_opts[@]" ;;
        tree|memory)
          _arguments '--all' '--groups[Group count]:count:' "$_cmux_target_opts[@]" ;;
        read-screen|capture-pane)
          _arguments '--scrollback' '--lines[Lines]:n:' "$_cmux_target_opts[@]" ;;
        send|send-panel)
          _arguments "$_cmux_target_opts[@]" '*:text:' ;;
        send-key|send-key-panel)
          _arguments "$_cmux_target_opts[@]" '*:key:' ;;
        notify)
          _arguments \
            '--title[Title]:text:' '--subtitle[Subtitle]:text:' \
            '--body[Body]:text:' "$_cmux_target_opts[@]" ;;
        set-status)
          _arguments \
            '1:key:' '2:value:' \
            '--icon[Icon]:name:' '--color[Color]:color:' \
            '--priority[Priority]:n:' "$_cmux_target_opts[@]" ;;
        set-progress)
          _arguments '1:value:' '--label[Label]:text:' "$_cmux_target_opts[@]" ;;
        log)
          _arguments \
            '--level[Level]:level:' '--source[Source]:name:' \
            "$_cmux_target_opts[@]" '*:message:' ;;
        events)
          _arguments \
            '--after[After seq]:seq:' '--cursor-file[Cursor file]:file:_files' \
            '--name[Event name]:event:' '--category[Category]:category:' \
            '--reconnect' '--limit[Limit]:n:' '--no-ack' '--no-heartbeat' ;;
        remote-daemon-status)
          _arguments '--os[OS]:os:(darwin linux)' '--arch[Arch]:arch:(arm64 amd64)' ;;
        find-window)
          _arguments '--content' '--select' '--window[Window]:window:_cmux_ref' '*:query:' ;;
        browser)
          if (( CURRENT == 2 )); then
            _cmux_browser
          else
            _arguments \
              '--surface[Target surface]:surface:_cmux_ref' \
              '--focus[Focus]:focus:(true false)' \
              '--snapshot-after[Snapshot after action]' \
              '*: :_default'
          fi ;;
        *)
          # Generic fallback: most commands accept the common target options.
          _arguments \
            "$_cmux_target_opts[@]" "$_cmux_focus_opts[@]" \
            '--id[UUID]:uuid:' '*: :_default' ;;
      esac
      ;;
  esac
}

_cmux "$@"
