#compdef cmux
# zsh completion for cmux — control cmux via Unix socket
# Generated from `cmux --help`.

# ---------------------------------------------------------------------------
# Reusable option fragments
#
# NOTE: the option arrays are built inside _cmux() (see below), NOT here.
# This file IS the body of the autoloaded _cmux function: on the first call it
# runs top-to-bottom and redefines _cmux to the inner definition at the bottom.
# Anything declared `local` out here only exists during that first call, so on
# every subsequent completion the arrays would be unset and _arguments would
# choke on empty specs ("invalid argument:"). Keep them function-local instead.
# ---------------------------------------------------------------------------

# Stub matcher for id/ref/index arguments — refs are dynamic, so just hint.
_cmux_ref() {
  _message -e ref 'id | ref | index'
}

_cmux_path() { _files }

