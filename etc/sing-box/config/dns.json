{
  "dns": {
    "servers": [
      // Local
      // { "tag": "dns-local", "type": "local" },
      // Resolver
      { "tag": "dns-pod-raw", "type": "udp", "server": "119.29.29.29" },
      { "tag": "dns-ali-raw", "type": "udp", "server": "223.5.5.5" },
      { "tag": "dns-ali-raw2", "type": "udp", "server": "223.6.6.6" },
      {
        "tag": "dns-resolver",
        "type": "group",
        "servers": ["dns-pod-raw", "dns-ali-raw", "dns-ali-raw2"]
      },
      // Direct
      { "tag": "dns-ali", "type": "h3", "server": "dns.alidns.com", "domain_resolver": "dns-resolver" },
      { "tag": "dns-pod", "type": "https", "server": "doh.pub", "domain_resolver": "dns-resolver" },
      {
        "tag": "dns-direct",
        "type": "group",
        "servers": ["dns-pod", "dns-ali"]
      },
      // Proxy
      // { "tag": "dns-google", "type": "h3", "server": "dns.google", "detour": "🔰 默认出口" },
      { "tag": "dns-one", "type": "h3", "server": "one.one.one.one", "detour": "🔰 默认出口" },
      { "tag": "dns-cloudflare", "type": "h3", "server": "cloudflare-dns.com", "detour": "🔰 默认出口" },
      {
        "tag": "dns-proxy",
        "type": "group",
        "servers": [
          // "dns-google",
          "dns-one",
          "dns-cloudflare"
        ]
      },
      // Gingkoo
      { "tag": "dns-gingkoo", "type": "udp", "server": "10.1.2.59" },
      // LazyCat
      { "tag": "dns-lazycat", "type": "udp", "server": "fc03:1136:3800::1" },
      // Tailscale
      { "tag": "dns-tailscale", "type": "tailscale", "endpoint": "tailscale-ep" },
      // Hosts
      { "tag": "dns-hosts", "type": "hosts", "path": ["hosts", "/etc/hosts"] },
      // mDNS
      // { "tag": "dns-mdns", "type": "mdns" },
      // FakeIP
      {
        "tag": "dns-fakeip",
        "type": "fakeip",
        "inet4_range": "22.0.0.0/8"
      }
    ],
    "rules": [
      // 直接解析
      { "preferred_by": "dns-hosts", "server": "dns-hosts" },
      // mDNS
      // { "preferred_by": "dns-mdns", "server": "dns-mdns" },
      // Tailscale
      { "preferred_by": "dns-tailscale", "server": "dns-tailscale" },
      // LazyCat
      { "domain_suffix": "heiyu.space", "server": "dns-lazycat" },
      // 内网地址
      { "domain_suffix": ["heiyu.space", "ts.net"], "rule_set": "Lan", "action": "predefined", "rcode": "NXDOMAIN" },
      // 公共 DNS
      {
        "domain": ["dns.alidns.com", "doh.pub", "dot.pub", "dns.google", "one.one.one.one", "cloudflare-dns.com"],
        "server": "dns-resolver"
      },
      // Gingkoo
      { "domain_suffix": ["server.gingkoo", "gingkoo.internal"], "server": "dns-gingkoo" },
      // Fake IP
      { "rule_set": "FakeIpBypass", "server": "dns-direct" },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          { "query_type": ["A", "AAAA"] },
          {
            "process_name": ["sing-box", "cdeplugin", "lzc-core.darwin", "openvpn", "tailscaled", "Tailscale", "q"],
            "invert": true
          }
        ],
        "server": "dns-fakeip",
        "rewrite_ttl": 1
      },
      // Clash 模式
      { "clash_mode": "Direct", "server": "dns-direct" },
      { "clash_mode": "Global", "server": "dns-proxy" },
      // 地理位置
      { "rule_set": "GeoSites@CN", "server": "dns-direct" },
      { "rule_set": "GeoSites@!CN", "server": "dns-proxy" },
      // CN IP 直接解析
      { "action": "evaluate", "server": "dns-direct" },
      { "match_response": true, "rule_set": "GeoIP@CN", "action": "respond" }
    ],
    "final": "dns-proxy",
    "reverse_mapping": true,
    "strategy": "prefer_ipv6"
  },
  "inbounds": [
    {
      "type": "direct",
      "tag": "dns-in",
      "listen": "127.0.0.1",
      "listen_port": 53
    }
  ],
  "route": {
    "rules": [
      // DNS inbound
      { "inbound": "dns-in", "action": "hijack-dns" },
      // Direct Process
      {
        "process_name": ["sing-box", "cdeplugin", "lzc-core.darwin", "openvpn", "tailscaled", "Tailscale"],
        "outbound": "DIRECT"
      },
      // Tailscale
      { "preferred_by": "tailscale-ep", "outbound": "tailscale-ep" },
      // Direct Destination
      { "network": "icmp", "outbound": "DIRECT" },
      { "ip_is_private": true, "outbound": "DIRECT" },
      // DNS
      { "action": "sniff" },
      { "protocol": "dns", "action": "hijack-dns" },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          { "process_name": "q", "invert": true },
          {
            "type": "logical",
            "mode": "or",
            "rules": [
              { "network": "tcp", "port": 853 }, // DoT
              { "protocol": ["http", "tls"], "rule_set": "DoH" } // DoH
            ]
          }
        ],
        "action": "reject"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          { "process_name": "q", "invert": true },
          {
            "type": "logical",
            "mode": "or",
            "rules": [
              { "network": "udp", "port": 853 }, // DoQ
              { "protocol": "quic", "rule_set": "DoH" } // DoH/3
            ]
          }
        ],
        "action": "reject",
        "method": "drop"  // 静默防风暴
      },
      // Direct Protocol
      // { "protocol": "stun", "action": "reject" }, // 禁用 STUN
      { "protocol": ["bittorrent", "ntp", "stun"], "outbound": "DIRECT" },
      // Direct Domain
      {
        "domain_suffix": ["server.gingkoo", "gingkoo.internal"],
        "invert": true,
        "action": "sniff-override-destination"
      }
    ],
    "default_domain_resolver": "dns-direct"
  }
}
// vim: ft=jsonc
