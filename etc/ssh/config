Include ~/.colima/ssh_config
Include ~/.orbstack/ssh/config

TCPKeepAlive yes

Host * !dkmooncat.heiyu.space !*.dkmooncat.heiyu.space
    ControlMaster auto
    ControlPath /tmp/%r@%h:%p
    ControlPersist 10m

Host 10.0.6.64
    User app

Host 10.1.2.16 10.1.2.34 10.1.2.35
    User app
    ProxyJump 10.1.2.57

Host 10.1.2.32
    User dev
    ProxyJump 10.1.2.57
    WarnWeakCrypto false

Host 10.1.2.57
    User root
    WarnWeakCrypto false

Host 10.1.3.11 10.1.3.24 10.1.3.25 10.1.3.28 10.1.3.29 10.1.3.30 10.1.3.34
    User gpp
    HostKeyAlgorithms +ssh-rsa
    PubkeyAcceptedKeyTypes +ssh-rsa
    WarnWeakCrypto false

Host git.server.gingkoo
    WarnWeakCrypto false

Host 192.168.50.1 asusrouter.com www.asusrouter.com router.asus.com router.dkmooncat.heiyu.space
    User moon
    Port 20022
    WarnWeakCrypto false

Host 192.168.50.11 dkmooncat.heiyu.space
    User root
    SetEnv TERM=xterm-256color

Host 192.168.50.12 aipod.dkmooncat.heiyu.space
    User nvidia

Host ubuntu.dkmooncat.heiyu.space
    User moon

Host 192.168.50.13 debian.dkmooncat.heiyu.space
    User moon
    SetEnv TERM=xterm-256color

Host debian.dkmooncat.heiyu.space
    Hostname 63-93f0-eb65-171c-3cf3-0.d.heiyu.space

Host 192.168.50.15 homeassistant.lan homeassistant.local homeassistant.dkmooncat.heiyu.space
    User hassio
    SetEnv TERM=xterm-256color

Host homeassistant.dkmooncat.heiyu.space
    Hostname 192.168.50.15
    ProxyJump 63-93f0-eb65-171c-3cf3-0.d.heiyu.space

Host ibm-linux.lan
    User vpcuser
    Hostname 162.133.134.50
    SetEnv TERM=xterm-256color
    WarnWeakCrypto false
    ProxyCommand nc -X 5 -x 127.0.0.1:7898 %h %p
    #ProxyCommand corkscrew 10.1.2.12 8118 %h %p

Host ibm-aix.lan
    User gpp
    Hostname 192.168.10.70
    SetEnv TERM=xterm-256color
    ProxyJump ibm-linux.lan
    RemoteForward 1521 10.0.2.20:1521
    RemoteForward 8888 10.1.2.11:80

